  roomType: 1
  questions:
  - question: "Banyodayken ilk \xF6nce ne yapard\u0131n\u0131z?"
    answers:
    - "Etraftaki oyuncaklar\u0131 toplard\u0131m"
    - "Kap\u0131y\u0131 a\xE7\u0131p dibine \xE7\xF6melirdim"
    - "K\xFCvetlerden birinin i\xE7ine girerdim"
    - "Ba\u015F\u0131m\u0131 ve ensemi koruyup sabit bir noktaya ge\xE7erdim"
    correctIndex: 3
  - question: "Deprem s\u0131ras\u0131nda banyoda en b\xFCy\xFCk risklerden biri
      nedir?"
    answers:
    - "Su ta\u015Fmas\u0131"
    - Fayans rengi
    - "Cam ve ayna k\u0131r\u0131lmas\u0131"
    - "Sabun d\xFC\u015Fmesi"
    correctIndex: 2
  - question: "Deprem s\u0131ras\u0131nda du\u015Fakabine yak\u0131nsan ne yapmal\u0131s\u0131n?"
    answers:
    - "Cam\u0131 tutmak"
    - Camdan uzak durmak
    - "Du\u015F almak"
    - "Kap\u0131y\u0131 kilitlemek"
    correctIndex: 1
